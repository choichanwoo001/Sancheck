VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# (optional) npm run db:migrate — Supabase Database connection URI
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres
VITE_APP_DEFAULT_USER_ID=dev_test_user_1
VITE_QR_LOGIN_TTL_SECONDS=90
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4.1-mini
VITE_OPENAI_TIMEOUT_MS=7000
# TTS 음성 선택: alloy | echo | fable | onyx | nova | shimmer (기본값: onyx — 낮은 톤)
VITE_TTS_VOICE=onyx
# Verso rosbridge WebSocket — 기본은 로컬 fake ROS. 실제 로봇은 이 URL만 ws://로봇IP:9090 형태로 변경
VITE_VERSO_ROSBRIDGE_URL=ws://127.0.0.1:9090

# 맵 전용 dev 모드 — true 시 온보딩·채팅 없이 3D 맵만 전체 화면. URL ?mapOnly=1 로도 가능
# VITE_MAP_DEV=true

# book_recognition FastAPI (로컬 uvicorn 8787, Vite dev 프록시 /book-recognition)
VITE_BOOK_RECOGNITION_MODE=http
VITE_BOOK_RECOGNITION_API_BASE=/book-recognition
# true면 책 인식 API 호출 없이 DB·화면 목록 매칭만 사용
# VITE_SHOPPING_LIST_SKIP_RECOGNITION=true

# 카카오페이 QR 결제 (서버 전용 — .env.local, VITE_ 붙이지 않음)
# 시연: Secret Key(Dev) + CID만 설정하면 됨. QR은 실 카카오페이 화면이 열리고, 웹 화면의 확인 버튼으로 완료 처리됨.
# 카카오페이 개발자센터 > 내 애플리케이션 > 카카오페이 > Secret Key (Dev)
KAKAO_PAY_SECRET_KEY=
# 테스트: TC0ONETIME / 실제 가맹점 CID
KAKAO_PAY_CID=TC0ONETIME
# (선택) Ready API 필수 파라미터용. 로컬 시연에서는 설정하지 않아도 됨.
# KAKAO_PAY_APPROVAL_BASE_URL=http://192.168.0.10:5173
# localhost 미등록 시 demo QR fallback (기본 true). 실카카오만 쓰려면 false
# KAKAO_PAY_DEMO_FALLBACK=true

# 카카오페이 QR 데모 — 권당 고정가 (원, 기본 15000)
# VITE_KAKAO_PAY_DEMO_BOOK_PRICE_KRW=15000
# VITE_KAKAO_PAY_API_BASE=/kakao-pay
