# =============================================================================
# 저장소 루트 .env — 한 파일에서 백엔드·AI·프론트(Vite)가 함께 참조합니다.
# 복사:  cp .env.example .env  후 값만 채우세요. .env 는 Git에 커밋하지 마세요.
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI (필수: 북챗, 하이브리드 추천 등 AI 모듈 전반)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# 정보나루 (국립중앙도서관 Open API) — https://www.data4library.kr/
# 필수: 북챗, 하이브리드 추천, Supabase 시드(sync_supabase_books_from_api), book_seeder 등
# -----------------------------------------------------------------------------
LIBRARY_API_KEY=

# -----------------------------------------------------------------------------
# 알라딘 TTB — 북챗 메타데이터, 표지 프록시(backend/main), 시드 스크립트 등
# ALADIN_API_KEY 를 우선 사용하고, 없으면 일부 코드가 ALADIN_TTB_KEY 를 봅니다.
# -----------------------------------------------------------------------------
ALADIN_API_KEY=
ALADIN_TTB_KEY=

# -----------------------------------------------------------------------------
# Supabase — 서버/로컬 스크립트만 (시드·export). service_role 은 절대 프론트에 넣지 마세요.
# 필수: seed_supabase_books, reseed_supabase_books, sync_supabase_books_from_api, export_books_catalog
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Supabase — 브라우저(React). Project Settings → API 의 anon public 키만 사용.
# 필수: 프론트에서 Supabase books 를 쓸 때 (없으면 로컬 JSON 폴백)
# Vite 는 루트 .env 의 VITE_* 를 읽습니다 (frontend/.env 가 아님).
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# 선택 — 하이브리드 추천 Supabase 영속 (서비스 롤 권장)
# KG: kg_nodes / kg_edges + clear_hybrid_kg RPC → 마이그레이션 20260425120000_bookjuk_full_schema.sql
# 임베딩: public.book_vectors (isbn 유니크 인덱스, upsert용) → 동일 마이그레이션에 포함
# HYBRID_PERSIST_KG=1 일 때 임베딩 동기화는 기본 켜짐. 끄려면 HYBRID_PERSIST_EMBEDDINGS=0
# hybrid_recommender_main.py: 사용자는 --supabase-user-id 또는 HYBRID_CLI_SUPABASE_USER_ID (없으면 dev_test_user_1)
# -----------------------------------------------------------------------------
# HYBRID_USE_SUPABASE=1
# HYBRID_PERSIST_KG=1
# HYBRID_PERSIST_EMBEDDINGS=1

# -----------------------------------------------------------------------------
# 선택 — 기본값 없이 두어도 되는 항목
# -----------------------------------------------------------------------------
# 레거시 env: 현재 저장소 Python 코드에서 읽지 않음(삭제해도 무방). 예전 취향 분석 CLI용이었음.
CLUSTERING_METHOD=kmeans

# Wikipedia 요청 시 User-Agent (비어 있으면 해당 경로에서 기본 동작)
WIKI_USER_AGENT=

# 표지/리소스 URL 조합용 API 베이스 (비어 있으면 상대 경로 등 기존 로직)
VITE_API_BASE_URL=
